# Environment file for Alloy
# Copy to /etc/alloy/env and fill in values
# Reference in systemd unit: EnvironmentFile=/etc/alloy/env

# === Endpoints ===
PROMETHEUS_REMOTE_WRITE_URL=https://prometheus.example.com/api/v1/write
PROMETHEUS_USERNAME=
PROMETHEUS_PASSWORD=
LOKI_WRITE_URL=https://loki.example.com/loki/api/v1/push
LOKI_USERNAME=
LOKI_PASSWORD=

# === Labels ===
ENVIRONMENT=dev
TEAM=
REGION=
SYSTEM=
SERVER_CLASS=
ZONE=

# === PostgreSQL ===
POSTGRES_DSN=postgresql://alloy:password@localhost:5432/postgres?sslmode=disable
